	  <script>
		const langBtns = document.querySelectorAll('#langBtn, #sp_langBtn');
		const langMenus = document.querySelectorAll('#langMenu, #sp_langMenu');
		const closeBtns = document.querySelectorAll('#closeBtn, #sp_closeBtn');

		const closeAllMenus = () => {
		  langBtns.forEach(btn => btn.setAttribute('aria-expanded', 'false'));
		  langMenus.forEach(menu => menu.classList.remove('show'));
		};

		// メニューの開閉
		langBtns.forEach((btn, index) => {
		  const menu = langMenus[index] || langMenus[0]; 

		  btn.addEventListener('click', (e) => {
			e.preventDefault();
			const isExpanded = btn.getAttribute('aria-expanded') === 'true';

			const newState = !isExpanded;
			btn.setAttribute('aria-expanded', newState);
			menu.classList.toggle('show', newState);
		  });
		});

		// 閉じるボタン
		closeBtns.forEach(btn => {
		  btn.addEventListener('click', (e) => {
			e.preventDefault();
			closeAllMenus();
		  });
		});

		// 外側クリック
		document.addEventListener('click', (e) => {
		  const isClickInside = 
			Array.from(langBtns).some(btn => btn.contains(e.target)) || 
			Array.from(langMenus).some(menu => menu.contains(e.target));

		  if (!isClickInside) {
			closeAllMenus();
		  }
		});

//日本語サイトのリンク用js
// data-url を持つ aタグだけ JS 遷移
document.querySelectorAll('#sp_langMenu a[data-url], #langMenu a[data-url]').forEach(a => {
  a.style.cursor = 'pointer';
  a.addEventListener('click', function(e) {
    e.preventDefault(); // aタグのデフォルト動作を止める
    const url = this.dataset.url;
    if (url) location.href = url;
  });
});

  </script>
	
	</header>
