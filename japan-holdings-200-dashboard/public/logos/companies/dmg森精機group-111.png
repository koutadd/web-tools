<script>
function getContents(url,checker){
  $.getJSON(url, function(data){
    var html = ""
    //checkerはHotContents:0, NewContents:1, AccessRanking:2
    if(checker == 2){
      html += "<ul class='itemList lanking column-4'>"
    }else if(checker == 1){
      html += "<ul class='itemList new-contents column-4'>"
    }else if(checker == 0){
      html += "<ul class='itemList hot-contents column-4'>"
    }
    var topicsList = data.topicsList
    var topCategoryList = $("#top-category-list").data('top-category-list')
    $.each(topicsList, function(key, item){
      html += "<li class='no-counter'>"
      if (item["topics_group_id"] == '13') {
        html += "<a href='/movie_library_movie/id="+item["topics_id"]+"' target='_blank'>"
      } else {
        html += "<a href='/topics_detail"+item["topics_group_id"]+"/id="+item["topics_id"]+"'>"
      }
      html += "<p class='label'>"
      html += topCategoryList[item["contents_type"]]["top_category_nm"]
      html += "</p>"
      html += "<div class='fig'>"
      html += "<p class='thumbnail'>"
      if(checker !== 2){
        if(item["new_flg"] == "1"){
          html += "<span class='lbl-new'>NEW</span>"
        }
      }
      var imagePath = item["image_url"]
      html += '<img src="'+imagePath+'" alt="'+item["ext_col_01"]+'"></p>'
      html += "</div>"
      html += "<div class='summary'>"
      html += "<p class='update'>"
      html += item["ymd_str"]
      html += "</p>"
      html += "<div class='box-description'>"
      html += "<p class='title'>"
      if(item["topics_group_id"] == "6" && item["ext_col_15"]){
        html += item["ext_col_15"]
      }else{
        html += item["subject"]
      }
      html += "</p>"
      html += "</div>"
      html += "</div>"
      html += "</a>"
      html += "</li>"
      
    })
    html += "</ul>"
    $("#itemList").html(html)
  })
}

$(function(){
  getContents('/new_contents/?data_format=json',1)
  $("div.filtering-tabs ul li").click(function(){
    $("div.filtering-tabs ul li.current").removeClass("current")
    $(this).addClass("current")
  });
})
</script>
</body>
</html>